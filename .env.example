# Copia este archivo como .env y llena tus valores reales.
# NUNCA subas el archivo .env real a git.

# Local (SQL Server en tu máquina o Docker):
DATABASE_URL=mssql+pyodbc://sa:TuPassword123@localhost:1433/niza_isabela?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# Azure SQL Database (cuando despliegues):
# DATABASE_URL=mssql+pyodbc://usuario@servidor:password@servidor.database.windows.net:1433/niza_isabela?driver=ODBC+Driver+18+for+SQL+Server

# Clave secreta para firmar los tokens de sesión (JWT).
# Genera una propia y única, nunca uses esta de ejemplo en producción:
# En PowerShell: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
